---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import lurlemur from "../assets/lurlemur.jpeg";
---

<BaseLayout
  title="Om — Asle Bass"
  description="Litt om Asle Bass — utvikler basert i Norge."
>
  <h1>Om</h1>

  <p>
    Hei, jeg er Asle. Jeg jobber som utvikler og er interessert i web,
    verktøybygging og hvordan man lager programvare som er enkel å forstå og
    enkel å vedlikeholde.
  </p>

  <p>
    Denne siden er stedet jeg samler tanker, notater og eksperimenter — uten
    planer for hvor ofte jeg publiserer eller hvor langt det skal være.
  </p>

  <h2>Finn meg andre steder</h2>
  <ul>
    <li>
      <a
        href="https://www.linkedin.com/in/asle-kinner%C3%B8d-a9909030/"
        rel="me"
      >
        LinkedIn
      </a>
    </li>
    <li><a href="mailto:hei@aslebass.no">hei@aslebass.no</a></li>
  </ul>

  <figure class="personal-photo">
    <Image src={lurlemur} alt="Asle med en surikat" width={320} />
  </figure>
</BaseLayout>
